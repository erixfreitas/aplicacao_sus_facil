# Arquivo .env - Configurações de Ambiente
# Copie este arquivo para .env.local para customizações locais

# Ambiente
AMBIENTE=desenvolvimento
DEBUG=True

# Logging
LOG_LEVEL=INFO

# Aplicação
APP_NAME=SUS Fácil
APP_VERSION=1.0.0

# Paginação
ITEMS_PER_PAGE=10

# Cache
ENABLE_CACHE=True
CACHE_TTL=3600

# Tema
THEME=light
PRIMARY_COLOR=#1f77b4

# Funcionalidades Experimentais
ENABLE_PDF_EXPORT=False
ENABLE_EXCEL_EXPORT=False
